# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed as the template.
#
# All GPU_EMBED_* variables map directly to EmbedConfig fields and can also
# be passed as CLI flags. CLI flags take precedence over env vars.

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

# Directory that holds Athena vocabulary CSVs (CONCEPT.csv, etc.)
# The embedder defaults to reading CONCEPT.csv from this directory.
GPU_EMBED_VOCAB_DIR=athena_vocab

# Optional source-concept parquet input (file or directory of *.parquet files).
# When set, `gpu-embed embed` reads Stage 0-style source-concept parquet rows
# instead of Athena CONCEPT.csv.
GPU_EMBED_SOURCE_PARQUET=

# Embedding store path. Backend is chosen by the path suffix:
# - `.lance` dir (default, recommended): ACID snapshots, cross-process readers,
#   and O(changes) merge_insert upserts (see docs/adr_lance_store_proposal.md).
# - `.duckdb` file path: native DuckDB table — fast single-writer local upserts.
#   Migrate an existing one with `gpu-embed migrate-lance --from embeddings.duckdb`.
# - Directory path (no suffix): opt-in parquet-sharded store — a migration/export
#   artifact, not a live write store (see docs/adr_parquet_store_rejected.md).
GPU_EMBED_DB=embeddings.lance

# Directory for CLI logs (dated files with size-based rotation).
GPU_EMBED_LOG_DIR=logs

# Maximum size per log file before rotating.
GPU_EMBED_LOG_MAX_BYTES=2097152

# Maximum number of log files to keep.
GPU_EMBED_LOG_MAX_FILES=5

# CSV ingest engine. DuckDB is the default; set to python for fallback/debug.
GPU_EMBED_INGEST_ENGINE=duckdb

# DB write engine. ndjson is default (faster bulk staging); set to direct to disable.
GPU_EMBED_WRITE_MODE=ndjson

# ---------------------------------------------------------------------------
# Embedding model
# ---------------------------------------------------------------------------

# Hugging Face model ID or local path to a biomedical embedding model that
# produces a 768-dim vector. SapBERT is the default; see the README's
# "Choosing an embedding model" for alternatives (e.g. FremyCompany/BioLORD-2023).
GPU_EMBED_MODEL=cambridgeltl/SapBERT-from-PubMedBERT-fulltext

# HuggingFace commit hash (or branch/tag) to pin the exact model revision.
# Leave blank to use the default branch (not recommended for production).
# Find the hash on the HF model page → Files → commit icon, e.g.:
#   https://huggingface.co/cambridgeltl/SapBERT-from-PubMedBERT-fulltext/commits/main
# The on-disk SHA-256 (model_version) will still verify what you actually got.
GPU_EMBED_MODEL_REVISION=

# Device: cuda | cpu | mps | auto  (auto = cuda → mps → cpu)
GPU_EMBED_DEVICE=auto

# Number of concept rows per GPU forward pass. Lower if you hit OOM.
GPU_EMBED_BATCH_SIZE=256

# Persist checkpoints every N embedding batches.
# Example with batch_size=256 and value=250 writes roughly every 64,000 rows.
GPU_EMBED_UPSERT_EVERY_BATCHES=250

# Tokenizer max sequence length (tokens). SapBERT was trained at 128.
GPU_EMBED_MAX_LENGTH=128

# Token pooling strategy: cls (SapBERT default) or mean (mask-aware average,
# for sentence-transformers models like BioLORD-2023). Non-default pooling is
# folded into model_version so cls and mean runs of the same weights don't
# collide on (namespace, concept_id, model_version).
GPU_EMBED_POOLING=cls

# Comma-separated list of CONCEPT.csv columns to concatenate as embed input.
# Example: concept_code,concept_name  →  "44054006: Type 2 diabetes mellitus"
GPU_EMBED_TEXT_FIELDS=concept_name

# Comma-separated list of source parquet fields to concatenate as embed input.
# Valid values: source_name, source_description, source_domain, ehr_codes,
# sample_units, sample_values, data_type, source_id. `concept_name` is accepted
# as an alias for `source_name`.
GPU_EMBED_SOURCE_TEXT_FIELDS=source_name

# String placed between concatenated text fields (only used when >1 field).
GPU_EMBED_SEPARATOR=" "

# Identity namespace for the concepts being embedded (default: athena).
# Athena standard concepts use "athena". Give source-concept datasets (local
# codes, free text) a distinct namespace so their concept_ids cannot collide
# with Athena on the (namespace, concept_id, model_version) primary key.
GPU_EMBED_NAMESPACE=athena

# Default namespace for source parquet runs. CLI `--namespace` still overrides
# this, but keeping a separate default helps avoid mixing source concepts into
# the Athena namespace by accident.
GPU_EMBED_SOURCE_NAMESPACE=source

# ---------------------------------------------------------------------------
# CPT-4 / UMLS  (required only for the `gpu-embed cpt4` subcommand)
# ---------------------------------------------------------------------------

# Your UMLS account API key.
# Obtain at: https://uts.nlm.nih.gov/uts/profile  → Generate API Key
UMLS_API_KEY=

# Path to the cpt4.jar shipped inside the Athena vocabulary download bundle.
# Athena places it at the root of the ZIP alongside the CSV files.
CPT4_JAR=athena_vocab/cpt4.jar
