# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed as the template.
#
# All GPU_EMBED_* variables map directly to EmbedConfig fields and can also
# be passed as CLI flags. CLI flags take precedence over env vars.

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

# Directory that holds Athena vocabulary CSVs (CONCEPT.csv, etc.)
# The embedder defaults to reading CONCEPT.csv from this directory.
GPU_EMBED_VOCAB_DIR=athena_vocab

# DuckDB output file
GPU_EMBED_DB=embeddings.duckdb

# Directory for CLI logs (dated files with size-based rotation).
GPU_EMBED_LOG_DIR=logs

# Maximum size per log file before rotating.
GPU_EMBED_LOG_MAX_BYTES=2097152

# Maximum number of log files to keep.
GPU_EMBED_LOG_MAX_FILES=5

# CSV ingest engine. DuckDB is the default; set to python for fallback/debug.
GPU_EMBED_INGEST_ENGINE=duckdb

# DB write engine. ndjson is default (faster bulk staging); set to direct to disable.
GPU_EMBED_WRITE_MODE=ndjson

# ---------------------------------------------------------------------------
# Embedding model
# ---------------------------------------------------------------------------

# Hugging Face model ID or local path to a SapBERT-compatible checkpoint.
GPU_EMBED_MODEL=cambridgeltl/SapBERT-from-PubMedBERT-fulltext

# HuggingFace commit hash (or branch/tag) to pin the exact model revision.
# Leave blank to use the default branch (not recommended for production).
# Find the hash on the HF model page → Files → commit icon, e.g.:
#   https://huggingface.co/cambridgeltl/SapBERT-from-PubMedBERT-fulltext/commits/main
# The on-disk SHA-256 (model_version) will still verify what you actually got.
GPU_EMBED_MODEL_REVISION=

# Device: cuda | cpu | mps | auto  (auto = cuda → mps → cpu)
GPU_EMBED_DEVICE=auto

# Number of concept rows per GPU forward pass. Lower if you hit OOM.
GPU_EMBED_BATCH_SIZE=256

# Tokenizer max sequence length (tokens). SapBERT was trained at 128.
GPU_EMBED_MAX_LENGTH=128

# Comma-separated list of CONCEPT.csv columns to concatenate as embed input.
# Example: concept_code,concept_name  →  "44054006: Type 2 diabetes mellitus"
GPU_EMBED_TEXT_FIELDS=concept_name

# String placed between concatenated text fields (only used when >1 field).
GPU_EMBED_SEPARATOR=" "

# ---------------------------------------------------------------------------
# CPT-4 / UMLS  (required only for the `gpu-embed cpt4` subcommand)
# ---------------------------------------------------------------------------

# Your UMLS account API key.
# Obtain at: https://uts.nlm.nih.gov/uts/profile  → Generate API Key
UMLS_API_KEY=

# Path to the cpt4.jar shipped inside the Athena vocabulary download bundle.
# Athena places it at the root of the ZIP alongside the CSV files.
CPT4_JAR=athena_vocab/cpt4.jar

# ---------------------------------------------------------------------------
# AWS execution path  (optional — only for the `gpu-embed aws-*` subcommands)
# ---------------------------------------------------------------------------
# These map to AwsConfig (env prefix GPU_EMBED_AWS_). Leave blank for local-only
# use. Requires the optional dependency: `uv pip install ".[aws]"` (boto3).

# AWS region for S3 + Batch clients.
GPU_EMBED_AWS_REGION=

# S3 bucket that holds input shards, output embeddings, and run manifests.
GPU_EMBED_AWS_S3_BUCKET=

# Key prefixes within the bucket.
GPU_EMBED_AWS_S3_INPUT_PREFIX=gpu-embedder/input
GPU_EMBED_AWS_S3_OUTPUT_PREFIX=gpu-embedder/output

# AWS Batch queue + job definition used by `aws-submit`.
GPU_EMBED_AWS_JOB_QUEUE=
GPU_EMBED_AWS_JOB_DEFINITION=

# Rows per shard (one AWS Batch array task per shard) and the array-size ceiling.
GPU_EMBED_AWS_SHARD_SIZE=50000
GPU_EMBED_AWS_MAX_ARRAY_SIZE=1000

# Prefer Spot capacity (informational; enforced by the Batch compute env).
GPU_EMBED_AWS_SPOT_PREFERRED=true
